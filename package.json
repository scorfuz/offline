{
  "name": "offline",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "turbo dev --filter=@offline/api --filter=@offline/web",
    "dev:api": "pnpm --filter @offline/api dev",
    "dev:web": "pnpm --filter @offline/web dev",
    "dev:mobile": "pnpm --filter @offline/mobile dev -- --ios",
    "dev:mobile-e2e:appium": "pnpm --filter @offline/mobile-e2e appium",
    "start:api": "pnpm --filter @offline/api start",
    "build": "turbo build",
    "build:api": "pnpm --filter @offline/api build",
    "build:web": "pnpm --filter @offline/web build",
    "build:mobile": "pnpm --filter @offline/mobile build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:mobile-e2e": "pnpm --filter @offline/mobile-e2e test",
    "test:mobile-e2e:smoke": "pnpm --filter @offline/mobile-e2e test:smoke",
    "test:mobile-e2e:projects-flow": "pnpm --filter @offline/mobile-e2e test:projects-flow",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
