# API Environment Variables
#
# Copy this file to .env and fill in the values.

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/base_template

# Server port (default: 3001)
PORT=3001

# Required: Public URL of this API server
API_ORIGIN=http://localhost:3001

# Public URL of the web app (used for CORS)
WEB_ORIGIN=http://localhost:3000

# Required: Secret for better-auth session signing (generate a random string)
BETTER_AUTH_SECRET=replace-me-with-a-random-secret

# Trusted origins for auth (comma-separated, defaults to WEB_ORIGIN)
AUTH_TRUSTED_ORIGINS=http://localhost:3000
