# Appium server
MOBILE_E2E_APPIUM_HOST=127.0.0.1
MOBILE_E2E_APPIUM_PORT=4723
MOBILE_E2E_APPIUM_PATH=/

# Device/session (Android example; switch to iOS + XCUITest when targeting the iOS dev build)
MOBILE_E2E_PLATFORM_NAME=Android
MOBILE_E2E_AUTOMATION_NAME=UiAutomator2
MOBILE_E2E_DEVICE_NAME=Android Emulator
# MOBILE_E2E_PLATFORM_VERSION=18.5

# App target (provide app path OR package/activity OR bundle id)
# Android examples:
# MOBILE_E2E_APP=/absolute/path/to/app-debug.apk
# MOBILE_E2E_APP_PACKAGE=<your.android.package>
# MOBILE_E2E_APP_ACTIVITY=.MainActivity
#
# iOS example for this repo's native app:
# MOBILE_E2E_PLATFORM_NAME=iOS
# MOBILE_E2E_AUTOMATION_NAME=XCUITest
# MOBILE_E2E_DEVICE_NAME=iPhone 16
# MOBILE_E2E_PLATFORM_VERSION=18.5
# MOBILE_E2E_BUNDLE_ID=ca.sumisura.offline.dev

# Flow test login (defaults match `pnpm --filter @offline/api db:seed`)
MOBILE_E2E_EMAIL=tech@test.com
MOBILE_E2E_PASSWORD=password1234

# Flow test tuning
MOBILE_E2E_TIMEOUT_MS=20000
MOBILE_E2E_ALLOW_EMPTY_PROJECTS=true
