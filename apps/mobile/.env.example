# Mobile Environment Variables
#
# Copy this file to .env and fill in the values.

# Required: API server origin
EXPO_PUBLIC_API_ORIGIN=http://localhost:3001

# Optional: PowerSync service origin
EXPO_PUBLIC_POWERSYNC_ENDPOINT=http://localhost:8080

# Local dev auth after `pnpm --filter @offline/api db:seed`:
#   email:    tech@test.com
#   password: password1234
