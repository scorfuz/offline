{
  "expo": {
    "name": "offline",
    "slug": "offline",
    "scheme": "offline",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      ["expo-dev-client", { "showFloatingButton": false }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "ca.sumisura.offline.dev"
    }
  }
}
