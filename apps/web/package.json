{
  "name": "@base-template/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "router:generate": "node scripts/generate-route-tree.mjs",
    "build": "pnpm router:generate && vite build && tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "typecheck": "pnpm router:generate && tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm router:generate && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@base-template/api-client": "workspace:*",
    "@base-template/contracts": "workspace:*",
    "@base-template/ui": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.166.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@tanstack/react-start-plugin": "^1.131.50",
    "@tanstack/router-generator": "1.166.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "nitro": "3.0.260311-beta",
    "typescript": "^5.8.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
